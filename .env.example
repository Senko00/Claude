# --- VK ---
# Токен сообщества "Симбирский крановый завод" (vk.ru/simkran).
# Группа -> Управление -> Работа с API -> Ключи доступа -> создать ключ
# с правами "Стена" и "Фотографии".
VK_TOKEN=
# Числовой ID сообщества (без минуса), видно в той же настройке или в URL.
VK_GROUP_ID=

# --- Google Gemini (бесплатный лимит) ---
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Bitrix (simkran.ru) ---
# Входящий вебхук: Марketplace -> Разработчикам -> Другое -> Входящий вебхук.
# Нужны права: iblock (инфоблоки).
BITRIX_WEBHOOK_URL=https://simkran.ru/rest/1/xxxxxxxxxxxxxxxx/
# ID инфоблока "Новости" (Контент -> Инфоблоки -> открыть раздел, ID в списке/URL).
BITRIX_IBLOCK_ID=
