# --- VK ---
# Токен сообщества "Симбирский крановый завод" (vk.ru/simkran).
# Группа -> Управление -> Работа с API -> Ключи доступа -> создать ключ
# с правами "Стена" и "Фотографии".
VK_TOKEN=
# Числовой ID сообщества (без минуса), видно в той же настройке или в URL.
VK_GROUP_ID=

# --- Ollama (локальная модель, полностью бесплатно и навсегда) ---
# 1. Установите Ollama: https://ollama.com/download (обычный установщик,
#    работает в фоне как служба на localhost:11434).
# 2. Один раз скачайте модель командой в PowerShell/терминале:
#    ollama pull qwen2.5:7b-instruct
#    (~4.7 ГБ, на слабом ПК без AVX2/с маленькой видеокартой генерация
#    одного поста может занимать 1-5 минут — это нормально).
# Менять ничего не нужно, если оставили модель по умолчанию.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Bitrix (simkran.ru) ---
# На этой инсталляции REST API не отдаёт методы iblock.* (см. README), поэтому
# публикация идёт через bitrix_endpoint.php, который нужно загрузить на сайт.
# URL, по которому вы разместили bitrix_endpoint.php на simkran.ru.
BITRIX_ENDPOINT_URL=https://simkran.ru/bitrix_endpoint.php
# Тот же секретный ключ, что вписан в bitrix_endpoint.php (константа SECRET).
BITRIX_ENDPOINT_SECRET=
# ID инфоблока "Новости" (Контент -> Инфоблоки -> открыть раздел, ID в списке/URL).
BITRIX_IBLOCK_ID=
