# --- VK ---
# Токен сообщества "Симбирский крановый завод" (vk.ru/simkran).
# Группа -> Управление -> Работа с API -> Ключи доступа -> создать ключ
# с правами "Стена" и "Фотографии".
VK_TOKEN=
# Числовой ID сообщества (без минуса), видно в той же настройке или в URL.
VK_GROUP_ID=

# --- GigaChat (Сбер, бесплатный лимит, работает без VPN из РФ) ---
# 1. https://developers.sber.ru/studio/workspaces -> создать проект "GigaChat API".
# 2. В настройках проекта скопировать "Ключ авторизации" (это Client ID и Client
#    Secret, уже склеенные и закодированные в base64) — вставить как есть.
GIGACHAT_API_KEY=
# GIGACHAT_API_PERS — тариф для физлиц (бесплатный лимит на старте).
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Опционально: путь к сертификату НУЦ Минцифры, если Python будет ругаться на
# SSL при обращении к API Сбера (см. README, раздел про GigaChat).
GIGACHAT_CA_BUNDLE=

# --- Bitrix (simkran.ru) ---
# Входящий вебхук: Марketplace -> Разработчикам -> Другое -> Входящий вебхук.
# Нужны права: iblock (инфоблоки).
BITRIX_WEBHOOK_URL=https://simkran.ru/rest/1/xxxxxxxxxxxxxxxx/
# ID инфоблока "Новости" (Контент -> Инфоблоки -> открыть раздел, ID в списке/URL).
BITRIX_IBLOCK_ID=
