# --- VK ---
# Токен сообщества "Симбирский крановый завод" (vk.ru/simkran).
# Группа -> Управление -> Работа с API -> Ключи доступа -> создать ключ
# с правами "Стена" и "Фотографии".
VK_TOKEN=
# Числовой ID сообщества (без минуса), видно в той же настройке или в URL.
VK_GROUP_ID=

# --- YandexGPT (Yandex Cloud, бесплатный грант, обычный SSL без сертификатов) ---
# 1. https://console.cloud.yandex.ru -> зарегистрироваться (нужна банковская
#    карта для подтверждения личности, но списаний не будет, пока не включите
#    платный тариф вручную) -> получить бесплатный грант.
# 2. Создать каталог (folder) -> скопировать его ID -> вставить в YANDEX_FOLDER_ID.
# 3. Сервисные аккаунты -> создать сервисный аккаунт с ролью ai.languageModels.user
#    -> создать API-ключ -> вставить в YANDEX_API_KEY.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# yandexgpt-lite — быстрее и попадает в бесплатный лимит с запасом.
YANDEX_MODEL=yandexgpt-lite

# --- Bitrix (simkran.ru) ---
# Входящий вебхук: Марketplace -> Разработчикам -> Другое -> Входящий вебхук.
# Нужны права: iblock (инфоблоки).
BITRIX_WEBHOOK_URL=https://simkran.ru/rest/1/xxxxxxxxxxxxxxxx/
# ID инфоблока "Новости" (Контент -> Инфоблоки -> открыть раздел, ID в списке/URL).
BITRIX_IBLOCK_ID=
